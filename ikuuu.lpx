#!name= ikuuu 签到
#!desc= 每日自动签到，支持 : 或 * 分隔
#!icon=https://raw.githubusercontent.com/你的用户名/仓库名/main/ikuuu.png
#!author=yourname

[Argument]
CRON定时设置=input,"0 9 * * *",tag=cron, desc=CRON定时设置
静默运行=input,"",tag=silent, desc=静默运行(填 # 静默，留空通知)
账号和密码=input,"",tag=account, desc=邮箱:密码 或 邮箱*密码

[Script]
cron {cron} script-path=ik.js, timeout=120, tag=ikuuu签到, argument=[{account},{silent}]