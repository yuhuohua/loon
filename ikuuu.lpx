#!name= ikuuu 签到
#!desc= 每日自动签到，格式：邮箱:密码
#!author= yourname

[Argument]
cron = input, "0 9 * * *", tag=定时设置, desc=每日自动运行的时间
account = input, "", tag=账号密码(邮箱:密码), desc=请填入 邮箱:密码 (例如 abc@qq.com:123456)
silent = switch, false, tag=静默运行, desc=开启后将不再弹出通知

[Script]
# 这里改回标准的 & 拼接，Loon 的底层会自动把它转为 {"account": "...", "silent": ...} 的对象
cron {cron} script-path=ikuuu.js, timeout=120, tag=ikuuu签到, argument=account={account}&silent={silent}
