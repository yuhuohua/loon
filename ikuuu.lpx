#!name= ikuuu 签到
#!desc= 每日自动签到，格式：邮箱:密码。示例： 123456@qq.com：123456。\n接口由贰月红大佬提供，感谢贰月红大佬。
#!icon=https://raw.githubusercontent.com/yuhuohua/tupiao/refs/heads/main/ikuuu.png
#!author=〈ザㄩメ火华

[Argument]
cron = input, "0 9 * * *", tag=定时设置, desc=每日自动运行的时间
account = input, "", tag=账号密码(邮箱:密码), desc=请填入 邮箱:密码 (例如 abc@qq.com:123456)
silent = switch, false, tag=静默运行, desc=开启后将不再弹出通知

[Script]
cron {cron} script-path=, timeout=120, tag=ikuuu签到, argument=[{account},{silent}]


